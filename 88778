-- === ЛОГИКА ===

-- Функция, которая пытается "уронить" игрока

local function tripPlayer(targetChar)
    local humanoid = targetChar:FindFirstChildOfClass("Humanoid")
    local hrp = targetChar:FindFirstChild("HumanoidRootPart")
    
    if humanoid and hrp then
        -- Способ 1: Заставить персонажа сесть (самый эффективный для падения)
        humanoid.Sit = true
        
        -- Способ 2: Дать импульс вверх/вниз, чтобы он потерял равновесие
        hrp.Velocity = Vector3.new(0, 50, 0) 
        
        -- Способ 3: Отключить физику (если позволяет эксплойт)
        -- humanoid.PlatformStand = true
    end
end

-- Цикл проверки касания

RunService.Stepped:Connect(function()
    if not Toggled then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    local myHRP = char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    -- Перебираем всех игроков
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetChar = player.Character
            local targetHRP = targetChar:FindFirstChild("HumanoidRootPart") 
            if targetHRP then
                -- Проверяем расстояние (имитация касания)
                -- Если ты подошел очень близко, скрипт сработает
                local distance = (myHRP.Position - targetHRP.Position).Magnitude
                
                if distance < 4 then -- 4 студа - это радиус касания
                    tripPlayer(targetChar)
                end
            end
        end
    end
end)

